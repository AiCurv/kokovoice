# Oracle Control Plane Environment Variables
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to the repository.

# Telegram Bot
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Single-user lock: ONLY this Telegram user ID may use the bot
ALLOWED_TELEGRAM_USER_ID=YOUR_TELEGRAM_USER_ID

# Telegram webhook secret — validated on every POST from Telegram
# Generate a random one: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
TELEGRAM_WEBHOOK_SECRET=YOUR_RANDOM_WEBHOOK_SECRET_HERE

# GitHub Actions Dispatch (use your fine-grained token for the kokovoicebot repo)
GITHUB_REPOSITORY_OWNER=YOUR_GITHUB_USERNAME
GITHUB_REPOSITORY_NAME=kokovoicebot
GITHUB_DISPATCH_TOKEN=YOUR_FINE_GRAINED_GITHUB_TOKEN

# Completion callback security (shared secret between Oracle and GitHub Actions)
# Generate: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
ORACLE_COMPLETION_SECRET=YOUR_RANDOM_COMPLETION_SECRET_HERE

# Server Configuration (existing Oracle VM at 130.210.12.9)
WEBHOOK_PORT=8443
WEBHOOK_URL_BASE=https://130.210.12.9
